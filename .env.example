# UMMG environment template. Copy to .env and fill in.

# Bearer token clients must send to the gateway.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
GATEWAY_BEARER_TOKEN=change-me-to-a-long-random-string

# Anthropic key (forwarded to headroom 8791 -> api.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# MiniMax key (forwarded to headroom 8792 -> api.minimax.io)
# Used as the OpenAI-compat key because MiniMax exposes an OpenAI-shaped endpoint.
MINIMAX_API_KEY=sk-...

# Z.ai GLM Coding Plan key (OpenAI-compatible coding endpoint:
# https://api.z.ai/api/coding/paas/v4). Optional unless a 'zai' upstream is
# configured in models.yaml. Sent as Authorization: Bearer <key>.
ZAI_API_KEY=

# Where to write persistent memory (FAISS + SQLite).
UMMG_DATA_DIR=C:\Tools\gateway\data